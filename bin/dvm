#!/usr/bin/env bash
set -euo pipefail

dvm_resolve_script_dir() {
	local source dir
	source="${BASH_SOURCE[0]}"
	while [ -L "$source" ]; do
		dir="$(cd -P "$(dirname "$source")" && pwd)"
		source="$(readlink "$source")"
		case "$source" in
		/*) ;;
		*) source="$dir/$source" ;;
		esac
	done
	cd -P "$(dirname "$source")" && pwd
}

DVM_CORE="${DVM_CORE:-$(cd "$(dvm_resolve_script_dir)/.." && pwd)}"
DVM_CONFIG="${DVM_CONFIG:-$HOME/.config/dvm}"
DVM_STATE="${DVM_STATE:-$HOME/.local/share/dvm}"

# shellcheck disable=SC1091
source "$DVM_CORE/lib/util.sh"
# shellcheck disable=SC1091
source "$DVM_CORE/lib/config.sh"
# shellcheck disable=SC1091
source "$DVM_CORE/lib/vm.sh"

dvm_help() {
	cat <<'HELP'
usage:
  dvm init [name]
  dvm edit <name>
  dvm create <name>
  dvm setup <name>
  dvm setup-all
  dvm upgrade <name>
  dvm upgrade-all
  dvm enter <name>
  dvm ssh <name> [command...]
  dvm ssh-key <name>
  dvm gpg-key <name>
  dvm list
  dvm rm <name> [--force]

Shortcut:
  dvm <name> enters that VM.
  dvm <name> <command...> runs a command in that VM.
HELP
}

dvm_main() {
	local cmd
	cmd="${1:-help}"
	[ "$#" -eq 0 ] || shift
	case "$cmd" in
	init) dvm_init "$@" ;;
	edit | config) dvm_edit "$@" ;;
	create | new) dvm_create "$@" ;;
	setup | update) dvm_setup "$@" ;;
	setup-all | update-all) dvm_setup_all "$@" ;;
	upgrade) dvm_upgrade "$@" ;;
	upgrade-all) dvm_upgrade_all "$@" ;;
	enter) dvm_enter "$@" ;;
	ssh) dvm_ssh "$@" ;;
	ssh-key | key) dvm_ssh_key "$@" ;;
	gpg-key) dvm_gpg_key "$@" ;;
	list | ls) dvm_list "$@" ;;
	rm | delete) dvm_rm "$@" ;;
	help | -h | --help) dvm_help ;;
	*)
		dvm_load_defaults
		if dvm_list_names | grep -Fxq "$cmd"; then
			if [ "$#" -eq 0 ]; then
				dvm_enter "$cmd"
			else
				dvm_ssh "$cmd" "$@"
			fi
		else
			dvm_help
			dvm_die "unknown command or VM: $cmd"
		fi
		;;
	esac
}

dvm_main "$@"
